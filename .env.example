DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/petdata
API_KEY_HASH=<sha256-of-your-api-key>
ADMIN_API_KEY_HASH=<sha256-of-your-admin-api-key>
PUBLIC_DATA_API_KEY=<data.go.kr-service-key>
KAKAO_REST_API_KEY=<카카오 개발자센터 REST API 키>
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
NAVER_CLIENT_ID=<네이버 개발자센터 Client ID>
NAVER_CLIENT_SECRET=<네이버 개발자센터 Client Secret>
HOSPITAL_API_KEY=<동물병원 API key>
REDIS_URL=redis://localhost:6379/0
# 그루밍 추천 MVP Feature flag (docs/GROOMING-RECOMMEND-MVP.md §1.1)
GROOMING_MVP_ENABLED=false
# 외부 API 타임아웃 (ms) — 운영 환경에서 덮어쓰기 가능 (§2.9)
NAVER_TIMEOUT_MS=10000
KAKAO_TIMEOUT_MS=8000
